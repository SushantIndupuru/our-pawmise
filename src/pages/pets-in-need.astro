---
import Layout from '../layouts/Layout.astro';
import {Image} from 'astro:assets';
import coco from '../assets/coco.jpg';
---
<Layout title="Pets in Need - Our Pawmise"
        description="Meet the pets and families Our Pawmise is helping. Stories and photos coming soon.">
    <main class="page">
        <header class="page-hero">
            <div class="wrap">
                <p class="eyebrow">Our Recipients</p>
                <h1>Pets in Need</h1>
                <p>
                    These are the pets receiving support through Our Pawmise, so you can see exactly who your donation is helping.
                </p>
            </div>
        </header>

        <section class="section">
            <div class="wrap narrow">
                <div class="pets-grid">
                    <figure class="pet-card">
                        <div class="pet-media">
                            <Image src={coco} alt="Coco" class="pet-photo" width={1161} height={1546} loading="lazy"/>
                        </div>
                        <figcaption>
                            <strong>Coco</strong>
                            <span>Meet Coco, a 7 year old boxer with a mast cell tumor. She needs your help!</span>
                            <a class="btn" href="/support">Donate to Help Coco</a>
                        </figcaption>
                    </figure>
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    .page {
        padding-top: 68px;
    }

    .page-hero {
        padding: 3rem 0 2rem;
    }

    @media (max-width: 480px) {
        .page-hero {
            padding: 2rem 0 1.25rem;
        }

        .section {
            padding: 1.5rem 0;
        }
    }

    .eyebrow {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        margin-bottom: 0.7rem;
    }

    h1 {
        font-size: clamp(2rem, 4vw, 2.8rem);
        margin-bottom: 0.8rem;
        letter-spacing: -0.03em;
    }

    p {
        color: var(--muted);
    }

    .narrow {
        max-width: 760px;
    }

    .section {
        padding: 2rem 0;
    }

    .pets-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
    }

    .pet-card {
        margin: 0;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--surface);
        overflow: hidden;
    }

    .pet-media {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        background: var(--border);
    }

    .pet-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    figcaption {
        padding: 1.1rem 1.25rem 1.4rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    figcaption strong {
        font-size: 1.15rem;
    }

    figcaption span {
        color: var(--muted);
        font-size: 0.95rem;
    }

    .btn {
        display: inline-block;
        margin-top: 0.85rem;
        padding: 0.7rem 1.25rem;
        border-radius: 6px;
        background: var(--accent);
        color: #fff;
        text-decoration: none;
        font-size: 0.95rem;
        align-self: flex-start;
    }
</style>
