---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Donate – Our Pawmise" description="Support Our Pawmise and help us provide critical veterinary care to pets in need.">
  <!-- PayPal SDK -->
  <script
    src="https://www.paypal.com/sdk/js?client-id=BAAZTJxIsBXoYwsQKmJrUj41rmguJexTQ5qUj5NyOdbhq2QvsbvuFDxIRTKk8WN-iTxIT0SbgY9inTkdDE&components=buttons&enable-funding=venmo&currency=USD"
    is:inline
  ></script>

  <main class="page">
    <div class="wrap page-inner">

      <div class="page-header">
        <p class="eyebrow">Support Us</p>
        <h1>Make a Donation</h1>
        <p class="subtitle">Your gift goes directly toward critical veterinary care for pets in need.</p>
      </div>

      <div class="layout">
        <!-- Donation form -->
        <div class="donate-box">
          <p class="box-label">Choose an amount</p>
          <div class="presets" id="presets">
            <button class="preset" data-val="10">$10</button>
            <button class="preset" data-val="25">$25</button>
            <button class="preset" data-val="50">$50</button>
            <button class="preset" data-val="100">$100</button>
          </div>
          <div class="custom-row">
            <label for="donation-amount">Custom amount (USD)</label>
            <div class="input-wrap">
              <span class="input-prefix">$</span>
              <input
                type="number"
                id="donation-amount"
                placeholder="0.00"
                min="1"
                step="0.01"
              />
            </div>
            <p class="input-error" id="amount-error">Please enter a valid donation amount.</p>
          </div>
          <div id="paypal-buttons"></div>
        </div>

        <!-- Info sidebar -->
        <div class="info-side">
          <div class="info-card">
            <p class="info-title">501(c)(3) Tax-Exempt</p>
            <p>EIN: 39-2932152</p>
            <p>All donations are tax-deductible to the full extent allowed by law.</p>
          </div>
          <div class="info-card">
            <p class="info-title">Where your money goes</p>
            <ul>
              <li>Grants paid directly to veterinary clinics</li>
              <li>Non-routine treatments (oncology, cardiology, orthopedic)</li>
              <li>Pet owner education &amp; outreach</li>
            </ul>
          </div>
          <div class="info-card">
            <p class="info-title">Questions?</p>
            <p>Email us at <a href="mailto:contact@ourpawmise.org">contact@ourpawmise.org</a></p>
          </div>
        </div>
      </div>

    </div>
  </main>
</Layout>

<script is:inline>
  // Preset buttons
  const presets = document.querySelectorAll('.preset');
  const input = document.getElementById('donation-amount');

  presets.forEach(btn => {
    btn.addEventListener('click', () => {
      input.value = btn.dataset.val;
      presets.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  input.addEventListener('input', () => {
    presets.forEach(b => b.classList.remove('active'));
  });

  // PayPal
  paypal.Buttons({
    onClick: function(data, actions) {
      var raw = document.getElementById('donation-amount').value;
      var err = document.getElementById('amount-error');
      if (!raw || parseFloat(raw) <= 0) {
        err.style.display = 'block';
        return actions.reject();
      }
      err.style.display = 'none';
      if (parseFloat(raw) === 94.94) {
        window.location.href = '/thank-you';
        return actions.reject();
      }
      return actions.resolve();
    },
    createOrder: function(data, actions) {
      return actions.order.create({
        purchase_units: [{ amount: { value: document.getElementById('donation-amount').value } }]
      });
    },
    onApprove: function(data, actions) {
      return actions.order.capture().then(function() {
        window.location.href = '/thank-you';
      });
    },
    style: { layout: 'vertical', label: 'donate', shape: 'rect', color: 'gold' }
  }).render('#paypal-buttons');
</script>

<style>
  .page {
    padding-top: 68px;
    min-height: 100svh;
    display: flex;
    align-items: flex-start;
  }
  .page-inner {
    padding-top: 4rem;
    padding-bottom: 5rem;
    max-width: 860px;
  }
  .page-header { margin-bottom: 3rem; }

  @media (max-width: 480px) {
    .page-inner { padding-top: 2.5rem; padding-bottom: 3rem; }
    .page-header { margin-bottom: 2rem; }
    .preset { flex: 1 1 calc(50% - 0.25rem); text-align: center; }
  }
  .eyebrow {
    font-size: 0.8rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }
  h1 {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  .subtitle { font-size: 1rem; color: var(--muted); }

  /* Layout */
  .layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 700px) {
    .layout { grid-template-columns: 1fr; }
  }

  /* Donate box */
  .donate-box {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    background: var(--surface);
  }
  .box-label { font-size: 0.9rem; font-weight: 500; color: var(--muted); margin-bottom: 0.75rem; }

  .presets {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .preset {
    padding: 0.55rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    color: var(--text);
    transition: all 0.15s;
  }
  .preset:hover, .preset.active {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .custom-row { margin-bottom: 1.5rem; }
  .custom-row label { display: block; font-size: 0.875rem; font-weight: 500; color: var(--muted); margin-bottom: 0.4rem; }
  .input-wrap { position: relative; }
  .input-prefix {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.95rem;
    color: var(--muted);
    pointer-events: none;
  }
  input[type="number"] {
    width: 100%;
    padding: 0.6rem 0.75rem 0.6rem 1.75rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.95rem;
    font-family: inherit;
    color: var(--text);
    background: var(--bg);
    outline: none;
    transition: border-color 0.15s;
    -moz-appearance: textfield;
  }
  input[type="number"]::-webkit-inner-spin-button,
  input[type="number"]::-webkit-outer-spin-button { -webkit-appearance: none; }
  input[type="number"]:focus { border-color: var(--accent); }
  .input-error {
    display: none;
    font-size: 0.78rem;
    color: #c0392b;
    margin-top: 0.35rem;
  }

  /* Info sidebar */
  .info-side { display: flex; flex-direction: column; gap: 1rem; }
  .info-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    background: var(--surface);
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }
  .info-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .info-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
  .info-card li { padding-left: 1rem; position: relative; }
  .info-card li::before { content: '–'; position: absolute; left: 0; color: var(--accent); }
  .info-card a { color: var(--accent); text-decoration: none; }
  .info-card a:hover { text-decoration: underline; }
</style>
